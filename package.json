{
  "name": "pact-network",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev:backend": "pnpm --filter @pact-network/backend dev",
    "dev:scorecard": "pnpm --filter @pact-network/scorecard dev",
    "dev": "turbo dev",
    "build:sdk": "pnpm --filter @q3labs/pact-monitor build && pnpm --filter @q3labs/pact-insurance build",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "test:sdk": "pnpm --filter @q3labs/pact-monitor test && pnpm --filter @q3labs/pact-insurance test",
    "test:backend": "pnpm --filter @pact-network/backend test",
    "test:smoke": "bash scripts/smoke.sh",
    "test:roundtrip": "pnpm build:sdk && pnpm --filter @pact-network/backend exec tsx ../../scripts/sdk-roundtrip.ts",
    "seed": "pnpm --filter @pact-network/backend seed",
    "generate-key": "pnpm --filter @pact-network/backend generate-key",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f postgres",
    "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
