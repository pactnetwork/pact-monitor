{
  "name": "pact-network",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:scorecard": "npm run dev -w packages/scorecard",
    "build:sdk": "npm run build -w packages/sdk",
    "build": "npm run build -w packages/sdk && npm run build -w packages/backend && npm run build -w packages/scorecard",
    "test": "npm run test:sdk && npm run test:backend",
    "test:sdk": "cd packages/sdk && npx tsx --test src/*.test.ts",
    "test:backend": "cd packages/backend && npx tsx --test src/**/*.test.ts",
    "seed": "npm run seed -w packages/backend",
    "generate-key": "npm run generate-key -w packages/backend"
  }
}
