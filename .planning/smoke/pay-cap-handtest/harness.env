# Hand-test harness env for the live facilitator route (C-1 refund cap).
# Sourced by start-harness.sh / call-cap-test.sh / stop-harness.sh.
# Devnet values taken from packages/{settler,market-proxy}/.env.devnet.example.
# RPC_URL uses the PUBLIC devnet endpoint (no Helius key needed) — the
# facilitator only hits RPC for the agent allowance read, which works on public.

# --- Facilitator service env (consumed by packages/facilitator/src/env.ts) ---
export PG_URL='postgresql://pact:pact@localhost:5544/pact'
export RPC_URL='https://api.devnet.solana.com'
export PROGRAM_ID='5jBQb7fLz8FNSsHcc9qLzULDRNL5MkHbjjXMqZodwrU5'
export USDC_MINT='4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU'
export PUBSUB_PROJECT='pact-handtest'
export PUBSUB_TOPIC='pact-settle-events'
export PUBSUB_EMULATOR_HOST='localhost:8685'
export PAY_DEFAULT_SLUG='pay-default'
# C-1 hand-test runs with the abuse gate OFF (today's zero-friction behaviour):
# the cap is enforced unconditionally in computeEconomics, NOT by this gate.
export PACT_VERDICT_ATTESTATION_GATE='off'
export PORT='8080'

# --- Harness-only knobs (NOT read by the facilitator) ---
export PUBSUB_SUB='handtest-sub'
export FACILITATOR_URL='http://localhost:8080'
# Agent wallet: primary is the hand-test wallet; fall back to pact-smoke (the
# one provisioned on devnet with a USDC ATA balance + delegation).
export WALLET_PRIMARY="$HOME/.config/pact/hand-test/wallet.json"
export WALLET_FALLBACK="$HOME/.config/pact/pact-smoke/wallet.json"
export PG_CONTAINER='pact-handtest-pg'
export PUBSUB_CONTAINER='pact-handtest-pubsub'
