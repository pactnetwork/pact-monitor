# dummy-upstream — Railway service env vars for devnet.
#
# Same shape as the mainnet packages/dummy-upstream/.env.production (Vercel
# project "dummy-upstream", scope "metalboyricks-projects"). PayAI mode ON
# — real x402 settlement happens, USDC actually moves on devnet via PayAI's
# hosted facilitator at https://facilitator.payai.network.
#
# Only three values differ from mainnet:
#   - DUMMY_X402_PAYAI_NETWORK: "solana" → "solana-devnet"
#   - DUMMY_X402_RPC_URL: mainnet-beta → api.devnet.solana.com
#   - DUMMY_X402_PAY_TO: mainnet pay-default wallet → devnet pay-default wallet
#
# Source: docs/superpowers/plans/2026-05-15-devnet-mirror-build.md
# Mirror of: packages/dummy-upstream/.env.production (mainnet, git-ignored)

# Required — flip on the real-settle code path. Without this the dummy
# stays in stamp-only emulation mode and no USDC moves.
DUMMY_X402_USE_PAYAI=1

# Required — settlement target. Mainnet uses
# DumgfMpzPTy2UxiKiiTU7mu9AVEcJGKQLUvCrnjref1G (the mainnet pay-default
# coverage pool's wallet). For devnet, set this to the equivalent devnet
# wallet pubkey — generate one via `solana-keygen new --outfile
# ~/pact-devnet-keys/pay-default.json` then bootstrap a devnet coverage
# pool with that wallet as authority.
#
# IMPORTANT: payTo MUST be a wallet pubkey (not a token account). x402-spec
# clients derive the destination via getAssociatedTokenAddress(payTo, USDC),
# so a raw token account here will simulate to InvalidAccountData. The
# mainnet vault `J55fpAi…` is a raw token account and so cannot be the
# payTo — same constraint applies on devnet.
DUMMY_X402_PAY_TO=<DEVNET_PAY_DEFAULT_POOL_WALLET_PUBKEY>

# Required — Solana network for the PayAI facilitator. Mainnet is "solana".
DUMMY_X402_PAYAI_NETWORK=solana-devnet

# Required — Solana RPC endpoint. Public devnet works for demo volume.
# Swap to Helius / QuickNode devnet if you start hitting rate limits.
DUMMY_X402_RPC_URL=https://api.devnet.solana.com

# Optional — PayAI facilitator URL. Same facilitator handles both
# mainnet and devnet; leave default unless PayAI publishes a
# devnet-specific endpoint.
# DUMMY_X402_FACILITATOR_URL=https://facilitator.payai.network

# Server
PORT=8080
