{
  "name": "@pact-network/indexer-evm",
  "version": "0.0.1",
  "private": true,
  "description": "NestJS service: subscribe to PactCore events on 0G Chain → write to Postgres → serve REST API.",
  "main": "dist/main.js",
  "scripts": {
    "deps": "pnpm --filter @pact-network/db-zerog --filter @pact-network/zerog-storage-client --filter @pact-network/protocol-zerog-client build",
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean && pnpm run deps",
    "pretest": "pnpm run deps",
    "pretypecheck": "pnpm run deps",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@pact-network/db-zerog": "workspace:*",
    "@pact-network/protocol-zerog-client": "workspace:*",
    "@pact-network/zerog-storage-client": "workspace:*",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "viem": "^2.49.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.4.0",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0"
  }
}
