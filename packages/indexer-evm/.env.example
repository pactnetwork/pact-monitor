# --- Postgres (db-zerog) ---
PG_URL_ZEROG=postgresql://localhost:5432/pact0g

# --- 0G Chain (single RPC — 0G is BFT-final, avoid cross-node head races) ---
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_CHAIN_ID=16602
PACT_CORE_ADDRESS=0x0000000000000000000000000000000000000000

# --- 0G Storage (per-call evidence reads → latencyMs/breach) ---
ZEROG_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# --- Indexer cursor / paging ---
# First block to scan on a fresh cursor (the PactCore deploy block).
INDEXER_START_BLOCK=0
# Tail poll cadence (0G blocks ~1-2s).
POLL_INTERVAL_MS=2000
# getLogs page size; conservative (0G public RPC limits undocumented).
# The reader bisects automatically on a range/result-limit error.
LOG_RANGE=500

LOG_LEVEL=log
PORT=3001
