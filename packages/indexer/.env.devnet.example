# indexer — Railway service env vars for devnet.
#
# Copy-paste these into Railway → indexer service → Variables.
# Source: docs/superpowers/plans/2026-05-15-devnet-mirror-build.md §5.3
#
# The indexer is the simplest service: TCP Postgres connection (not a
# Cloud SQL unix socket like mainnet), so `prisma migrate deploy` works
# natively from the railway.json preDeployCommand.

DATABASE_URL=${{Postgres.DATABASE_URL}}

# Push-secret guard for POST /events ingest from the settler. Must match
# the value in the settler service exactly (mainnet Bug 2 mitigation —
# see memory mainnet_first_settle_2026_05_07.md).
INDEXER_PUSH_SECRET=<OPENSSL_RAND_HEX_32_SAME_AS_SETTLER_SERVICE>

# Chain-sync (so endpoints_loaded > 0 on /health and /api/endpoints works)
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=<HELIUS_DEVNET_API_KEY>
PROGRAM_ID=5jBQb7fLz8FNSsHcc9qLzULDRNL5MkHbjjXMqZodwrU5

PORT=3001
