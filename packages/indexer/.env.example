# Postgres connection (Cloud SQL or local)
PG_URL=postgresql://pact:pact@localhost:5433/pact

# HTTP port the Nest server listens on
PORT=3001

# Bearer secret the settler uses to push to /events (PushSecretGuard)
INDEXER_PUSH_SECRET=<shared-secret>

# Helius webhook ingestion shared secret (legacy webhook controller)
HELIUS_WEBHOOK_SECRET=<shared-secret>

# Pact Network V1 program ID — mainnet by default. Override for devnet.
PROGRAM_ID=5bCJcdWdKLJ7arrMVMFh3z99rQDxV785fnD9XGcr3xwc

# Solana RPC the chain → DB sync uses to read EndpointConfig PDAs every 5
# minutes. Public mainnet endpoint is rate-limited; prefer Helius/Triton
# in production.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
