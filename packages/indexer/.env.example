# Postgres connection (Cloud SQL or local)
PG_URL=postgresql://pact:pact@localhost:5433/pact

# HTTP port the Nest server listens on
PORT=3001

# Bearer secret the settler uses to push to /events (PushSecretGuard)
INDEXER_PUSH_SECRET=<shared-secret>

# Helius webhook ingestion shared secret (legacy webhook controller)
HELIUS_WEBHOOK_SECRET=<shared-secret>

# Pact Network V1 program ID — mainnet by default. REQUIRED override for
# devnet (the code default is mainnet for prod safety; a devnet deploy that
# omits this scans the mainnet program and syncs nothing — the service logs
# a warning when SOLANA_RPC_URL looks like devnet but this is unset):
#   devnet PROGRAM_ID=5jBQb7fLz8FNSsHcc9qLzULDRNL5MkHbjjXMqZodwrU5
PROGRAM_ID=5bCJcdWdKLJ7arrMVMFh3z99rQDxV785fnD9XGcr3xwc

# Solana RPC the chain → DB sync uses to read EndpointConfig PDAs every 5
# minutes. Public mainnet endpoint is rate-limited; prefer Helius/Triton
# in production.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Refund-push webhook delivery (off by default) ---
# Master switch. When "true", INDEXER_WEBHOOK_SIGNING_SECRET is REQUIRED
# (delivery self-disables with an error log otherwise).
WEBHOOK_DELIVERY_ENABLED=false
# bs58-encoded 64-byte ed25519 secret key the indexer signs webhooks with.
# Its PUBLIC key is logged at boot and must be pinned by agents as
# createPact({ webhook: { indexerSigningKey } }). NOT a per-agent secret.
INDEXER_WEBHOOK_SIGNING_SECRET=
# Tuning (defaults shown). Replay window on the SDK side is 300s; keep the
# total retry span (attempts × backoff) well under that.
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=4
WEBHOOK_BACKOFF_BASE_MS=500
WEBHOOK_MAX_BODY_BYTES=262144
WEBHOOK_MAX_FAIL_COUNT=20
