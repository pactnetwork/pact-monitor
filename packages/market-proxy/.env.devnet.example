# market-proxy — Railway service env vars for devnet.
#
# Copy-paste these into Railway → market-proxy service → Variables.
# Substitute the bracketed values; the ${{...}} references are
# Railway's cross-service variable resolution and stay literal.
#
# Source of truth: docs/superpowers/plans/2026-05-15-devnet-mirror-build.md §5.3
#
# Mainnet contrast: mainnet ENV_PROD has no QUEUE_BACKEND key (defaults
# to "pubsub"). Setting QUEUE_BACKEND=redis-streams here flips the
# event sink to ioredis XADD against the Railway Redis plugin.

# Queue
QUEUE_BACKEND=redis-streams
REDIS_URL=${{Redis.REDIS_URL}}
REDIS_STREAM=pact-settle-events

# Postgres (used by EndpointRegistry + Allowlist)
PG_URL=${{Postgres.DATABASE_URL}}

# Solana
RPC_URL=https://devnet.helius-rpc.com/?api-key=<HELIUS_DEVNET_API_KEY>
PROGRAM_ID=5jBQb7fLz8FNSsHcc9qLzULDRNL5MkHbjjXMqZodwrU5
USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# Internal endpoints
INDEXER_URL=https://indexer-devnet.pactnetwork.io

# Operator-allowlist admin endpoint guard
ENDPOINTS_RELOAD_TOKEN=<OPENSSL_RAND_HEX_32>

# Helius API key (upstream provider for the `helius` endpoint slug)
PACT_HELIUS_API_KEY=<HELIUS_DEVNET_API_KEY>

# Private-beta gate fallback (PR #198) — leave "false" for devnet
PACT_BETA_GATE_ENABLED=false

# Server
PORT=8080
