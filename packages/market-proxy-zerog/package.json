{
  "name": "@pact-network/market-proxy-zerog",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Hono proxy: wraps 0G Compute inference calls with Pact insurance. ECDSA agent auth, ERC20 balance check, wrapFetch to settler.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
