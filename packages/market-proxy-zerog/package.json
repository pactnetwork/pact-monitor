    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.9.0",
    "@hono/node-server": "^1.13.7",
    "@pact-network/protocol-zerog-client": "workspace:*",
    "@pact-network/wrap": "workspace:*",
    "@pact-network/zerog-compute-client": "workspace:*",
    "ethers": "^6.13.4",
    "hono": "^4.7.0",
    "lru-cache": "^11.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  }
