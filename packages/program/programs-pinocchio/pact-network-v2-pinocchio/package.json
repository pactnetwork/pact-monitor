{
  "name": "pact-network-v2-pinocchio-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LiteSVM integration tests for pact-network-v2-pinocchio. Local-only; no CI wiring (matches V1).",
  "scripts": {
    "build:bypass": "cargo build-sbf --manifest-path Cargo.toml --features bpf-entrypoint,unsafe-bypass-deployer",
    "build:no-bypass": "cargo build-sbf --manifest-path Cargo.toml --features bpf-entrypoint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@q3labs/pact-protocol-v2-client": "workspace:*",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^22.10.5",
    "litesvm": "^0.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
