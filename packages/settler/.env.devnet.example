# settler — Railway service env vars for devnet.
#
# Copy-paste these into Railway → settler service → Variables.
# Substitute the bracketed values; the ${{...}} references are
# Railway's cross-service variable resolution and stay literal.
#
# Source: docs/superpowers/plans/2026-05-15-devnet-mirror-build.md §5.3
#
# Mainnet contrast: mainnet ENV_PROD has PUBSUB_PROJECT + PUBSUB_SUBSCRIPTION
# and no QUEUE_BACKEND key (defaults to "pubsub"). This file sets
# QUEUE_BACKEND=redis-streams and supplies the REDIS_* fields instead.

# Queue
QUEUE_BACKEND=redis-streams
REDIS_URL=${{Redis.REDIS_URL}}
REDIS_STREAM=pact-settle-events
REDIS_CONSUMER_GROUP=settler

# Multi-network. Comma-separated list of network slugs the settler boots
# adapters for. Unset defaults to "solana-devnet" only, which silently
# disables EVM settlement even if EVM RPC envs are present.
PACT_ENABLED_NETWORKS=solana-devnet,base-sepolia,arc-testnet

# Solana
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=<HELIUS_DEVNET_API_KEY>
PROGRAM_ID=5jBQb7fLz8FNSsHcc9qLzULDRNL5MkHbjjXMqZodwrU5
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Per-network EVM RPC URLs (one per non-Solana network in PACT_ENABLED_NETWORKS).
PACT_RPC_URL_SOLANA_DEVNET=https://devnet.helius-rpc.com/?api-key=<HELIUS_DEVNET_API_KEY>
PACT_RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
PACT_RPC_URL_ARC_TESTNET=https://rpc.testnet.arc.network

# Settlement authority — paste the base58-encoded keypair string here.
# Generate with `solana-keygen pubkey --outfile -` against the key json.
# Per plan §12 settled decisions: reusing the existing dev hot key.
SETTLEMENT_AUTHORITY_KEY=<BASE58_KEYPAIR_FROM_~/.config/solana/>

# EVM settler signer (per network). Raw 0x-hex private key for the EOA that
# submits settle_batch txs on each EVM chain in PACT_ENABLED_NETWORKS. Read
# by AdaptersService at boot (packages/settler/src/adapters/adapters.service.ts).
# Phase 2 will also accept "projects/<gcp>/secrets/.../versions/latest" paths.
# PACT_SETTLER_KEYPAIR_ARC_TESTNET=0x...
# PACT_SETTLER_KEYPAIR_BASE_SEPOLIA=0x...

# Indexer push (internal — uses Railway private networking)
INDEXER_URL=https://${{indexer.RAILWAY_PRIVATE_DOMAIN}}
INDEXER_PUSH_SECRET=<OPENSSL_RAND_HEX_32_SAME_AS_INDEXER_SERVICE>

# Logging
LOG_LEVEL=log
PORT=8080
