PUBSUB_PROJECT=your-gcp-project-id
PUBSUB_SUBSCRIPTION=pact-settle-events-settler
SOLANA_RPC_URL=https://api.devnet.solana.com
# In prod: "projects/<project>/secrets/pact-settlement-authority-devnet/versions/latest"
# In local dev: raw base58 private key of a dev keypair
SETTLEMENT_AUTHORITY_KEY=<base58-encoded-secret-key>
# Pact Network V1 program ID (post-Step-C devnet redeploy). The pre-refactor
# orphan at DhWibM... runs the old binary and MUST NOT be contacted.
PROGRAM_ID=5jBQb7fLz8FNSsHcc9qLzULDRNL5MkHbjjXMqZodwrU5
# Optional: override USDC mint (defaults to devnet USDC).
# USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# NOTE: POOL_VAULT_PUBKEY is no longer used. Per-endpoint coverage pools mean
# each event's pool is resolved from its slug at submit time (cached 60s).
INDEXER_URL=https://indexer.pactnetwork.io
INDEXER_PUSH_SECRET=<shared-secret>
LOG_LEVEL=log
PORT=8080
