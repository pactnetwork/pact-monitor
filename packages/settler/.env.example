# Queue backend. One of:
#   pubsub        — mainnet / Cloud Run. Requires PUBSUB_PROJECT + PUBSUB_SUBSCRIPTION.
#   redis-streams — devnet on Railway. Requires REDIS_URL + REDIS_STREAM.
#   memory        — local dev only. In-process queue, no durability, no
#                   GCP/Redis required. NOT for production.
# Unset defaults to "pubsub" to preserve mainnet behavior byte-for-byte.
QUEUE_BACKEND=pubsub
PUBSUB_PROJECT=your-gcp-project-id
PUBSUB_SUBSCRIPTION=pact-settle-events-settler

# Multi-network. Comma-separated list of network slugs the settler boots
# adapters for. Unset defaults to "solana-devnet" only, which silently
# disables EVM settlement even if EVM RPC envs are present. Include every
# network you want this settler instance to submit for.
PACT_ENABLED_NETWORKS=solana-devnet,base-sepolia,arc-testnet

# Per-network RPC URLs. SOLANA_RPC_URL is the legacy/canonical Solana var;
# the PACT_RPC_URL_* form is read by the EVM adapters for each chain in
# PACT_ENABLED_NETWORKS.
SOLANA_RPC_URL=https://api.devnet.solana.com
PACT_RPC_URL_SOLANA_DEVNET=https://api.devnet.solana.com
PACT_RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
PACT_RPC_URL_ARC_TESTNET=https://rpc.testnet.arc.network
# In prod: "projects/<project>/secrets/pact-settlement-authority-devnet/versions/latest"
# In local dev: raw base58 private key of a dev keypair
SETTLEMENT_AUTHORITY_KEY=<base58-encoded-secret-key>
# EVM settler signer (per network). Raw 0x-hex private key for the EOA that
# submits settle_batch txs on each EVM chain in PACT_ENABLED_NETWORKS. Read
# by AdaptersService at boot (packages/settler/src/adapters/adapters.service.ts).
# Phase 2 will also accept "projects/<gcp>/secrets/.../versions/latest" paths.
# PACT_SETTLER_KEYPAIR_ARC_TESTNET=0x...
# PACT_SETTLER_KEYPAIR_BASE_SEPOLIA=0x...
# Pact Network V1 program ID (post-Step-C devnet redeploy). The pre-refactor
# orphan at DhWibM... runs the old binary and MUST NOT be contacted.
PROGRAM_ID=5jBQb7fLz8FNSsHcc9qLzULDRNL5MkHbjjXMqZodwrU5
# Optional: override USDC mint (defaults to devnet USDC).
# USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# NOTE: POOL_VAULT_PUBKEY is no longer used. Per-endpoint coverage pools mean
# each event's pool is resolved from its slug at submit time (cached 60s).
INDEXER_URL=https://indexer.pactnetwork.io
INDEXER_PUSH_SECRET=<shared-secret>
LOG_LEVEL=log
PORT=8080
