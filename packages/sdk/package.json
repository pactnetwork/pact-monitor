{
  "name": "@q3labs/pact-sdk",
  "version": "0.1.0",
  "description": "Unified Pact Network agent SDK: createPact() + pact.fetch(). Proxy-backed parametric refund coverage for any registered API on Pact Network V1.",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "_build:deps": "pnpm --filter @q3labs/pact-protocol-v1-client build",
    "prebuild": "pnpm run _build:deps",
    "build": "tsc",
    "clean": "rm -rf dist",
    "pretypecheck": "pnpm run _build:deps",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm run _build:deps",
    "test": "vitest run",
    "test:e2e": "vitest run src/__tests__/integration.test.ts",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "smoke:pack": "bash scripts/smoke-pack.sh"
  },
  "keywords": [
    "pact-network",
    "solana",
    "x402",
    "agent",
    "fetch",
    "insurance",
    "refund"
  ],
  "license": "MIT",
  "author": "Pact Network",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@q3labs/pact-protocol-v1-client": "workspace:*",
    "@solana/web3.js": "^1.95.8",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.4",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
