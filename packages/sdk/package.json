{
  "name": "@pact-network/sdk",
  "version": "0.1.0",
  "description": "Unified Pact Network agent SDK: createPact() + pact.fetch(). Proxy-backed parametric refund coverage for any registered API on Pact Network V1.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "_build:deps": "pnpm --filter @pact-network/protocol-v1-client --filter @pact-network/wrap build",
    "prebuild": "pnpm run _build:deps",
    "build": "tsc",
    "clean": "rm -rf dist",
    "pretypecheck": "pnpm run _build:deps",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm run _build:deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "pact-network",
    "solana",
    "x402",
    "agent",
    "fetch",
    "insurance",
    "refund"
  ],
  "license": "MIT",
  "author": "Pact Network",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pact-network/protocol-v1-client": "workspace:*",
    "@pact-network/wrap": "workspace:*",
    "@solana/web3.js": "^1.95.8",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
