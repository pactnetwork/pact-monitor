{
  "name": "@pact-network/settler-v2",
  "version": "0.1.0",
  "private": true,
  "description": "V2 oracle-cranker — consumes V2SettlementEvent from Pub/Sub or Redis Streams, packs settle_premium and submit_claim instructions, drives the V2 indexer.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.9.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@pact-network/db-v2": "workspace:*",
    "@pact-network/wrap-v2": "workspace:*",
    "@q3labs/pact-protocol-v2-client": "workspace:*",
    "@solana/web3.js": "^1.95.8",
    "axios": "^1.7.9",
    "bs58": "^6.0.0",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0"
  }
}
