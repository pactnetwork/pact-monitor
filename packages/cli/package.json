    "@solana/web3.js": "^1.95.0",
    "tweetnacl": "^1.0.3",
    "bs58": "^6.0.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "hono": "^4.0.0",
    "typescript": "^5.4.0"
  }
