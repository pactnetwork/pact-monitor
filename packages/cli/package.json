{
  "name": "@q3labs/pact-cli",
  "version": "0.2.6",
  "type": "module",
  "bin": {
    "pact": "bin/pact.cjs"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "_build:deps": "pnpm --filter @pact-network/protocol-v1-client build",
    "_check:version": "node -e \"const a=require('./package.json').version,b=require('fs').readFileSync('src/index.ts','utf8').match(/VERSION\\s*=\\s*\\\"([^\\\"]+)/)[1]; if(a!==b){console.error('VERSION drift: package.json='+a+' src/index.ts='+b);process.exit(1)}\"",
    "prebuild": "pnpm run _build:deps && pnpm run _check:version",
    "build": "bun build src/index.ts --compile --target=bun --outfile dist/pact",
    "build:platforms": "pnpm run _build:deps && pnpm run _check:version && bash scripts/build-platforms.sh",
    "pretest": "pnpm run _build:deps",
    "test": "bun test",
    "pretypecheck": "pnpm run _build:deps",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint not configured yet'"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pact-network",
    "solana",
    "cli",
    "ai-agent",
    "x402"
  ],
  "license": "MIT",
  "author": "Pact Network",
  "devDependencies": {
    "@pact-network/protocol-v1-client": "workspace:*",
    "@q3labs/pact-monitor": "workspace:*",
    "@solana/kit": "^2.0.0",
    "@solana/web3.js": "^1.95.0",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "bs58": "^6.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.4.0"
  }
}
