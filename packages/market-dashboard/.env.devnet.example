# market-dashboard — Railway service env vars for devnet.
#
# Two flavors:
#   1. Build-time vars (NEXT_PUBLIC_*) — must be set as Railway "Build
#      Variables" on the service so Next.js bakes them into the client
#      bundle. Setting them as plain Variables will NOT work.
#   2. Runtime vars (PORT, etc.) — set as normal Railway Variables.
#
# Source: docs/superpowers/plans/2026-05-15-devnet-mirror-build.md §4.6 + §5.3

# === BUILD VARIABLES (set under Railway → Settings → Build → Build Variables) ===
NEXT_PUBLIC_INDEXER_URL=https://indexer-devnet.pactnetwork.io
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# === RUNTIME VARIABLES (Variables tab) ===
PORT=3000
