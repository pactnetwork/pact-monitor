# @pact-network/market-dashboard — env template
#
# Copy to `.env.local` for local dev, or set on Vercel for previews/prod.
# All NEXT_PUBLIC_* variables are baked into the client bundle at build time.

# ---------------------------------------------------------------------------
# Solana RPC endpoint used by the client and the SSR pass.
# Defaults to public devnet when unset. Use a Helius / Triton URL for prod.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# ---------------------------------------------------------------------------
# USDC mint the dashboard derives ATAs against.
#
# Production deploys MUST set this to the mainnet mint — otherwise the
# dashboard reports `no_ata` for every wallet because it derives the wrong ATA.
#
# - devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# - mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
#
# Falls back to devnet when unset.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# NEXT_PUBLIC_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ---------------------------------------------------------------------------
# Pact Network indexer base URL.
#
# When set, `lib/api/index.ts` swaps the in-memory mock for a real fetcher
# that hits the indexer's read API:
#
#   GET /api/stats
#   GET /api/endpoints, /api/endpoints/:slug
#   GET /api/agents/:pubkey, /api/agents/:pubkey/calls?limit=N
#   GET /api/calls/:id
#
# Leave unset for local dev / Vercel preview to keep the mock fixture data.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_INDEXER_URL=https://indexer.pactnetwork.io

# ---------------------------------------------------------------------------
# Pact Market proxy base URL — reserved for the wave 2 self-serve flow.
# Not consumed by the dashboard yet.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_PROXY_URL=https://market.pactnetwork.io
